{
  "name": "@markets/component-host",
  "version": "1.0.0",
  "private": true,
  "description": "Lightweight component wrapper providing OpenFin platform services (identity, config, theme) to registered components.",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./react": "./react/index.ts",
    "./angular": "./angular/index.ts"
  },
  "scripts": {
    "build": "tsc --noEmit --project tsconfig.json"
  },
  "dependencies": {
    "@markets/openfin-workspace": "*",
    "@marketsui/config-service": "*"
  },
  "peerDependencies": {
    "react": ">=19.2.4",
    "@angular/core": ">=21.0.0"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true },
    "@angular/core": { "optional": true }
  }
}
