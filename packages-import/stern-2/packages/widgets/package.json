{
  "name": "@stern/widgets",
  "version": "1.0.0",
  "description": "Stern Widgets — SimpleBlotter and future trading widgets",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
