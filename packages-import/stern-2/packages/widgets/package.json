    "build": "tsc",
    "watch": "tsc --watch",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "ag-grid-community": "^33.0.0",
    "ag-grid-react": "^33.0.0",
    "ag-grid-enterprise": "^33.0.0",
    "@tanstack/react-query": "^5.0.0",
    "lucide-react": ">=0.300.0",
    "@openfin/workspace": "^22.3.27",
    "@openfin/workspace-platform": "^22.3.27"
  },
  "dependencies": {
    "@stern/shared-types": "1.0.0",
    "@stern/widget-sdk": "1.0.0",
    "@stern/ui": "1.0.0",
    "@stomp/stompjs": "^7.3.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "ag-grid-community": "^33.0.0",
    "ag-grid-react": "^33.0.0",
    "ag-grid-enterprise": "^33.0.0",
    "rimraf": "^5.0.5",
    "typescript": "^5.3.3"
