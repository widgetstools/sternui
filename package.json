{
  "name": "marketsui-platform",
  "version": "0.1.0",
  "private": true,
  "description": "MarketsUI platform — starui-platform is the active codebase; root packages/ is legacy reference being retired.",
  "packageManager": "npm@10.9.0",
  "workspaces": [
    "starui-platform",
    "starui-platform/packages/shared/*",
    "starui-platform/packages/react/*",
    "starui-platform/packages/angular/*",
    "starui-platform/packages/angular/hosts/*",
    "starui-platform/packages/angular/providers/*",
    "starui-platform/packages/angular/widgets/*",
    "starui-platform/packages/angular/tools/*",
    "starui-platform/apps/*",
    "starui-platform/apps/demo-apps/*",
    "e2e-openfin"
  ],
  "scripts": {
    "build": "npm run build --workspace=starui-platform",
    "typecheck": "npm run typecheck --workspace=starui-platform",
    "test": "npm run test --workspace=starui-platform",
    "dev": "npm run dev:demo-react",
    "dev:demo-react": "npm run dev:demo-react --workspace=starui-platform",
    "dev:demo-configservice-react": "npm run dev:demo-configservice-react --workspace=starui-platform",
    "dev:basic-starui-app": "npm run dev:basic-starui-app --workspace=starui-platform",
    "dev:mockdata-provider-starui-app": "npm run dev:mockdata-provider-starui-app --workspace=starui-platform",
    "dev:dataprovider-editor-starui-app": "npm run dev:dataprovider-editor-starui-app --workspace=starui-platform",
    "dev:demo-angular": "npm run dev:demo-angular --workspace=starui-platform",
    "dev:openfin": "concurrently -k -n vite,openfin -c cyan,magenta \"npm run dev:demo-react -- --no-open\" \"wait-on http://localhost:5190 && node tools/scripts/launch-openfin.mjs http://localhost:5190/openfin/manifest.json\"",
    "dev:openfin:markets-react": "concurrently -k -n vite,openfin -c cyan,magenta \"npm run dev:markets-ui-react-reference -- --no-open\" \"wait-on http://localhost:5174 && node tools/scripts/launch-openfin.mjs http://localhost:5174/platform/manifest.fin.json\"",
    "dev:markets-ui-react-reference": "npm run dev:markets-ui-react-reference --workspace=starui-platform",
    "dev:stomp": "npm run dev:stomp --workspace=starui-platform",
    "launch:openfin": "node tools/scripts/launch-openfin.mjs",
    "e2e": "npm run e2e --workspace=starui-platform",
    "e2e:headed": "npm run e2e:headed --workspace=starui-platform",
    "e2e:ui": "npm run e2e:ui --workspace=starui-platform",
    "test:e2e:openfin": "npm run test:e2e -w @starui/e2e-openfin",
    "test:e2e:openfin:cdp": "npm run test:e2e -w @starui/e2e-openfin -- specs/02-cdp-smoke.e2e.spec.ts",
    "propagate": "npm run propagate --workspace=starui-platform",
    "verify:apps": "npm run verify:apps --workspace=starui-platform",
    "mcp:pack": "node mcp/scripts/pack.mjs",
    "clean": "rimraf -g node_modules starui-platform/node_modules starui-platform/packages/*/*/node_modules starui-platform/apps/*/node_modules .turbo starui-platform/.turbo"
  },
  "devDependencies": {
    "@openfin/node-adapter": "43.101.2",
    "@playwright/test": "^1.59.1",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.0.0",
    "postcss": "^8.5.9",
    "rimraf": "^6.0.1",
    "tailwindcss": "3.4.1",
    "tailwindcss-animate": "^1.0.7",
    "turbo": "^2.9.14",
    "wait-on": "^8.0.0"
  },
  "optionalDependencies": {
    "@rollup/rollup-darwin-arm64": "4.60.4",
    "@rollup/rollup-darwin-x64": "4.60.4",
    "@rollup/rollup-linux-arm64-gnu": "4.60.4",
    "@rollup/rollup-linux-x64-gnu": "4.60.4",
    "@rollup/rollup-win32-arm64-msvc": "4.60.4",
    "@rollup/rollup-win32-x64-msvc": "4.60.4"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "overrides": {
    "@openfin/core": "43.101.2"
  }
}
