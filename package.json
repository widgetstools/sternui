{
  "name": "marketsui-platform",
  "version": "0.1.0",
  "private": true,
  "description": "MarketsUI platform — modular Markets UI monorepo.",
  "packageManager": "npm@10.9.0",
  "workspaces": [
    "packages/design-system/*",
    "packages/angular-ui/*",
    "packages/react-ui/*",
    "packages/angular-grid/*",
    "packages/react-grid/*",
    "packages/data/*",
    "packages/openfin/*",
    "packages/angular-core/*",
    "packages/react-core/*",
    "packages/shared/*",
    "apps/*",
    "apps/demo-apps/*",
    "e2e-openfin"
  ],
  "scripts": {
    "build:packages": "turbo build --filter=!./apps/**",
    "build:apps": "turbo build --filter=./apps/**",
    "build:consumer": "npm run build:packages && node scripts/propagate.mjs && npm run build:apps",
    "build": "npm run build:consumer",
    "typecheck:packages": "turbo typecheck --filter=!./apps/**",
    "typecheck:apps": "turbo typecheck --filter=./apps/**",
    "typecheck:consumer": "npm run build:packages && node scripts/propagate.mjs --skip-drift-check && npm run typecheck:apps",
    "typecheck": "npm run typecheck:consumer",
    "test:packages": "turbo test --filter=!./apps/**",
    "test": "npm run test:packages",
    "check:tarballs": "npm run build:packages && node scripts/propagate.mjs --check-only --no-install",
    "verify:consumer": "npm run build:consumer && npm run typecheck:apps",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "e2e:ui": "playwright test --ui",
    "dev": "npm run dev:demo-react",
    "dev:demo-react": "npm run dev --workspace=@starui/demo-react",
    "dev:demo-configservice-react": "npm run dev --workspace=@starui/demo-configservice-react",
    "dev:demo-angular": "npm run start --workspace=@starui/demo-angular",
    "dev:basic-starui-app": "npm run dev --workspace=@starui/basic-starui-app",
    "dev:mockdata-provider-starui-app": "npm run dev --workspace=@starui/mockdata-provider-starui-app",
    "dev:dataprovider-editor-starui-app": "npm run dev --workspace=@starui/dataprovider-editor-starui-app",
    "dev:my-stomp-app": "npm run dev --workspace=@starui/my-stomp-app",
    "dev:markets-ui-react-reference": "npm run dev --workspace=@starui/markets-ui-react-reference",
    "dev:stomp": "npm run dev --workspace=@starui/stomp-view-server",
    "dev:demo": "npm run dev:demo-react",
    "dev:openfin": "concurrently -k -n vite,openfin -c cyan,magenta \"npm run dev:demo-react -- --no-open\" \"wait-on http://localhost:5190 && node tools/scripts/launch-openfin.mjs http://localhost:5190/openfin/manifest.json\"",
    "dev:openfin:markets-react": "concurrently -k -n vite,openfin -c cyan,magenta \"npm run dev:markets-ui-react-reference -- --no-open\" \"wait-on http://localhost:5174 && node tools/scripts/launch-openfin.mjs http://localhost:5174/platform/manifest.fin.json\"",
    "launch:openfin": "node tools/scripts/launch-openfin.mjs",
    "test:e2e:openfin": "npm run test:e2e -w @starui/e2e-openfin",
    "test:e2e:openfin:cdp": "npm run test:e2e -w @starui/e2e-openfin -- specs/02-cdp-smoke.e2e.spec.ts",
    "propagate": "node scripts/propagate.mjs",
    "sync:app-deps": "node scripts/sync-app-tarball-deps.mjs",
    "verify:apps": "node scripts/verify-apps.mjs",
    "check:deps": "node scripts/check-package-cycles.mjs",
    "check:deps:strict": "node scripts/check-package-cycles.mjs --strict",
    "clean": "rimraf -g node_modules packages/*/*/node_modules packages/*/*/dist apps/*/node_modules apps/demo-apps/*/node_modules .turbo"
  },
  "devDependencies": {
    "@openfin/node-adapter": "43.101.2",
    "@playwright/test": "^1.59.1",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.0.0",
    "postcss": "^8.5.9",
    "rimraf": "^6.0.1",
    "tailwindcss": "3.4.1",
    "tailwindcss-animate": "^1.0.7",
    "turbo": "^2.9.14",
    "typescript": "~5.9.3",
    "vitest": "^4.1.4",
    "wait-on": "^8.0.0"
  },
  "optionalDependencies": {
    "@rollup/rollup-darwin-arm64": "4.60.4",
    "@rollup/rollup-darwin-x64": "4.60.4",
    "@rollup/rollup-linux-arm64-gnu": "4.60.4",
    "@rollup/rollup-linux-x64-gnu": "4.60.4",
    "@rollup/rollup-win32-arm64-msvc": "4.60.4",
    "@rollup/rollup-win32-x64-msvc": "4.60.4"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "overrides": {
    "@openfin/core": "43.101.2",
    "esbuild": "0.28.0",
    "hono": "^4.12.20"
  }
}
