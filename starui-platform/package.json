{
  "name": "starui-platform",
  "version": "0.1.0",
  "private": true,
  "description": "StarUI — modular Markets UI platform with host ports for browser and OpenFin",
  "packageManager": "npm@10.9.0",
  "workspaces": [
    "packages/shared/*",
    "packages/react/*",
    "packages/angular/*",
    "apps/*",
    "apps/demo-apps/*"
  ],
  "scripts": {
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "e2e:ui": "playwright test --ui",
    "dev": "npm run dev:demo-react",
    "dev:demo-react": "npm run dev --workspace=@starui/demo-react",
    "dev:demo-configservice-react": "npm run dev --workspace=@starui/demo-configservice-react",
    "dev:demo-angular": "npm run start --workspace=@starui/demo-angular",
    "dev:basic-starui-app": "npm run dev --workspace=@starui/basic-starui-app",
    "dev:mockdata-provider-starui-app": "npm run dev --workspace=@starui/mockdata-provider-starui-app",
    "dev:dataprovider-editor-starui-app": "npm run dev --workspace=@starui/dataprovider-editor-starui-app",
    "dev:markets-ui-react-reference": "npm run dev --workspace=@starui/markets-ui-react-reference",
    "dev:stomp": "npm run dev --workspace=@starui/stomp-view-server",
    "dev:demo": "npm run dev:demo-react",
    "propagate": "node scripts/propagate.mjs",
    "verify:apps": "node scripts/verify-apps.mjs",
    "clean": "rimraf -g node_modules packages/*/*/node_modules packages/*/*/dist .turbo"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.0",
    "rimraf": "^6.0.1",
    "turbo": "^2.9.14",
    "typescript": "~5.9.3",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "overrides": {
    "@openfin/core": "43.101.2"
  }
}
