{
  "name": "marketsgrid-view",
  "appliesTo": ["openfin"],
  "newFiles": [
    { "src": "view.tsx", "dest": "src/views/{{ViewName}}.tsx" }
  ],
  "patches": [
    {
      "file": "src/main.tsx",
      "anchor": "// @starui:add-lazy-import-here",
      "insert": "const {{ViewName}} = React.lazy(() => import(\"./views/{{ViewName}}\"));",
      "idempotencyMarker": "import(\"./views/{{ViewName}}\")",
      "description": "Register lazy import of the view"
    },
    {
      "file": "src/main.tsx",
      "anchor": "{/* @starui:add-route-here */}",
      "insert": "<Route path=\"{{route}}\" element={<React.Suspense fallback={LOADING}><{{ViewName}} /></React.Suspense>} />",
      "idempotencyMarker": "path=\"{{route}}\"",
      "description": "Register route in main.tsx"
    },
    {
      "file": "src/platform/Provider.tsx",
      "anchor": "// @starui:add-prefetch-here",
      "insert": "{{ViewName}}: () => import(\"../views/{{ViewName}}\"),",
      "idempotencyMarker": "import(\"../views/{{ViewName}}\")",
      "description": "Add prefetch entry for warm-cache on first open"
    }
  ]
}
