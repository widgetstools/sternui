{
  "name": "{{name}}",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --port {{port}}",
    "dev:stomp": "npm --workspace tools/stomp-view-server run dev",
    "build": "tsc -b && vite build",
    "build:stomp": "npm --workspace tools/stomp-view-server run build",
    "typecheck": "tsc -b",
    "preview": "vite preview",
    "client": "node launch.mjs http://localhost:{{port}}/platform/manifest.fin.json"
  },
  "workspaces": ["tools/*"],
