{
  "licenseKey": "openfin-demo-license-key",
  "runtime": {
    "arguments": "--enable-mesh --security-realm={{platformUuid}} --remote-debugging-port=9090",
    "version": "43.142.101.2"
  },
  "$comment-devtools": "devtools_port + --remote-debugging-port together expose the OpenFin runtime to Chrome DevTools. Open chrome://inspect#devices in a separate Chrome window and click 'Configure...' → add 'localhost:9090', then SharedWorkers (data-services) appear under 'Other'.",
  "devtools_port": 9090,
  "platform": {
    "uuid": "{{platformUuid}}",
    "icon": "http://localhost:{{port}}/dock-provider.png",
    "autoShow": false,
    "providerUrl": "http://localhost:{{port}}/platform/provider",
    "preventQuitOnLastWindowClosed": true
  },
  "shortcut": {
    "company": "{{name}}",
    "description": "OpenFin workspace app scaffolded with @starui/mcp-server.",
    "icon": "http://localhost:{{port}}/favicon.ico",
    "name": "{{name}}",
    "target": ["desktop", "start-menu"]
  },
  "supportInformation": {
    "company": "{{name}}",
    "product": "{{name}}",
    "email": "support@example.com",
    "forwardErrorReports": true
  },
  "customSettings": {
    "seedConfigUrl": "http://localhost:{{port}}/seed-config.json",
    "$comment-useRest": "Master switch for REST mode. true + non-empty configServiceRestUrl → every ConfigManager in the platform (Provider + main-thread bundle + SharedWorker hub) writes to the REST server first, mirrors to Dexie, queues pendingSync on transient failures. false (or unset) → local Dexie only.",
    "useRest": {{useRest}},
    "configServiceRestUrl": "{{configServiceRestUrl}}",
    "apps": [
      {
        "appId": "{{name}}-view1",
        "name": "{{name}}-view1",
        "title": "View 1",
        "description": "FDC3 broadcast + OpenFin notifications demo",
        "manifest": "http://localhost:{{port}}/views/view1.fin.json",
        "manifestType": "view",
        "icons": [{ "src": "http://localhost:{{port}}/favicon.ico" }],
        "contactEmail": "contact@example.com",
        "supportEmail": "support@example.com",
        "publisher": "{{name}}",
        "intents": [],
        "images": [],
        "tags": ["view", "openfin"]
      },
      {
        "appId": "{{name}}-view2",
        "name": "{{name}}-view2",
        "title": "View 2",
        "description": "FDC3 context listener demo",
        "manifest": "http://localhost:{{port}}/views/view2.fin.json",
        "manifestType": "view",
        "icons": [{ "src": "http://localhost:{{port}}/favicon.ico" }],
        "contactEmail": "contact@example.com",
        "supportEmail": "support@example.com",
        "publisher": "{{name}}",
        "intents": [],
        "images": [],
        "tags": ["view", "openfin"]
      }
    ]
  }
}
