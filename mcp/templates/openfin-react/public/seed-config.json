{
  "permissions": [
    { "permissionId": "config:read",    "description": "View component configurations", "category": "config" },
    { "permissionId": "config:write",   "description": "Create and update component configurations", "category": "config" },
    { "permissionId": "config:delete",  "description": "Delete component configurations", "category": "config" },
    { "permissionId": "snapshot:read",  "description": "View workspace snapshots", "category": "snapshot" },
    { "permissionId": "snapshot:write", "description": "Save workspace snapshots", "category": "snapshot" }
  ],
  "roles": [
    {
      "roleId": "admin",
      "displayName": "Administrator",
      "permissionIds": ["config:read", "config:write", "config:delete", "snapshot:read", "snapshot:write"]
    },
    {
      "roleId": "developer",
      "displayName": "Developer",
      "permissionIds": ["config:read", "config:write", "snapshot:read", "snapshot:write"]
    }
  ],
  "appRegistry": [
    {
      "appId": "{{name}}",
      "displayName": "{{name}}",
      "manifestUrl": "http://localhost:{{port}}/platform/manifest.fin.json",
      "configServiceEnabled": false,
      "environment": "dev"
    }
  ],
  "userProfiles": [
    {
      "userId": "dev1",
      "appId": "{{name}}",
      "roleIds": ["admin", "developer"],
      "displayName": "Developer"
    }
  ]
}
