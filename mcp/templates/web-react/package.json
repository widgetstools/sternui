{
  "name": "{{name}}",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port {{port}}",
    "dev:stomp": "npm --workspace tools/stomp-view-server run dev",
    "build": "tsc && vite build",
    "build:stomp": "npm --workspace tools/stomp-view-server run build",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview"
  },
  "workspaces": ["tools/*"],
  "dependencies": {
    "@starui/core": "file:./libs/<TARBALL:@starui/core>",
    "@starui/design-system": "file:./libs/<TARBALL:@starui/design-system>",
    "@starui/grid-react": "file:./libs/<TARBALL:@starui/grid-react>",
    "@starui/icons-svg": "file:./libs/<TARBALL:@starui/icons-svg>",
    "@starui/markets-grid": "file:./libs/<TARBALL:@starui/markets-grid>",
    "@starui/shared-types": "file:./libs/<TARBALL:@starui/shared-types>",
    "@starui/ui": "file:./libs/<TARBALL:@starui/ui>",
    "@widgetstools/dock-manager-core": "^1.0.0",
    "@widgetstools/react-dock-manager": "^1.0.0",
    "ag-grid-community": "35.1.0",
    "ag-grid-enterprise": "35.1.0",
    "ag-grid-react": "35.1.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.460.0",
    "react": "~19.2.5",
    "react-dom": "~19.2.5",
    "tailwind-merge": "^2.5.4"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "~4.5.2",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.9",
    "tailwindcss": "3.4.1",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "~5.9.3",
    "vite": "~7.3.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
