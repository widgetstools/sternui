{
  "name": "@starui/eslint-plugin",
  "version": "0.1.0",
  "private": true,
  "description": "Custom ESLint rules that enforce StarUI Platform conventions — nested-field factory usage, logger-based diagnostics, and other consistency checks documented in docs/PUBLIC_API_SPEC.md.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "rimraf dist tsconfig.tsbuildinfo && tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "peerDependencies": {
    "eslint": "^9.0.0"
  },
  "dependencies": {
    "@typescript-eslint/utils": "^8.0.0"
  },
  "devDependencies": {
    "@typescript-eslint/parser": "^8.0.0",
    "@typescript-eslint/rule-tester": "^8.0.0",
    "eslint": "^9.0.0",
    "rimraf": "^6.0.1",
    "typescript": "~5.9.3",
    "vitest": "^4.0.0"
  },
  "keywords": [
    "eslint",
    "eslintplugin",
    "starui"
  ]
}
