{
  "name": "@marketsui/design-system",
  "version": "0.1.0",
  "private": true,
  "description": "MarketsUI design system — primitives, semantic tokens, themes, and framework adapters. Consolidates fi-trading-terminal tokens + stern-2 UI wrappers.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./themes/fi-dark.css": "./src/themes/fi-dark.css",
    "./themes/fi-light.css": "./src/themes/fi-light.css",
    "./tokens/primitives": {
      "types": "./dist/tokens/primitives.d.ts",
      "import": "./dist/tokens/primitives.js"
    },
    "./tokens/semantic": {
      "types": "./dist/tokens/semantic.d.ts",
      "import": "./dist/tokens/semantic.js"
    },
    "./tokens/components": {
      "types": "./dist/tokens/components.d.ts",
      "import": "./dist/tokens/components.js"
    },
    "./adapters/ag-grid": {
      "types": "./dist/adapters/ag-grid.d.ts",
      "import": "./dist/adapters/ag-grid.js"
    },
    "./adapters/shadcn": {
      "types": "./dist/adapters/shadcn.d.ts",
      "import": "./dist/adapters/shadcn.js"
    },
    "./adapters/primeng": {
      "types": "./dist/adapters/primeng.d.ts",
      "import": "./dist/adapters/primeng.js"
    },
    "./cell-renderers": {
      "types": "./dist/cell-renderers.d.ts",
      "import": "./dist/cell-renderers.js"
    }
  },
  "scripts": {
    "build": "rimraf dist tsconfig.tsbuildinfo && tsc --project tsconfig.json",
    "typecheck": "tsc --noEmit --project tsconfig.json"
  },
  "peerDependencies": {
    "ag-grid-community": ">=35.0.0"
  },
  "devDependencies": {
    "ag-grid-community": "35.1.0",
    "rimraf": "^5.0.5",
    "typescript": "~5.9.3"
  },
  "files": [
    "dist",
    "src/themes",
    "src/icons"
  ]
}
