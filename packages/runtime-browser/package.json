{
  "name": "@marketsui/runtime-browser",
  "version": "0.1.0",
  "description": "Browser implementation of @marketsui/runtime-port. URL params for identity, prefers-color-scheme + [data-theme] for theme, window.open for popouts.",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "rimraf dist tsconfig.tsbuildinfo && tsc",
    "watch": "tsc --watch",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@marketsui/runtime-port": "0.1.0"
  },
  "devDependencies": {
    "jsdom": "^29.0.2",
    "rimraf": "^5.0.5",
    "typescript": "~5.9.3",
    "vitest": "^4.1.4"
  },
  "license": "MIT"
}
