{
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "outDir": "dist",
    "rootDir": "src",
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "strictPropertyInitialization": false,
    "lib": ["ES2021", "DOM", "DOM.Iterable"],
    "moduleResolution": "bundler"
  },
  "include": ["src"]
}
