{
  "name": "@marketsui/widget-sdk",
  "version": "1.0.0",
  "description": "Stern Widget SDK — useWidget hook, WidgetHost, PlatformAdapter, extensibility",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "rimraf dist tsconfig.tsbuildinfo && tsc",
    "watch": "tsc --watch",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@marketsui/shared-types": "1.0.0",
    "@tanstack/react-query": "^5.0.0",
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0"
  },
  "dependencies": {
    "@marketsui/config-service": "1.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "rimraf": "^5.0.5",
    "typescript": "~5.9.3"
  },
  "keywords": [
    "stern",
    "widget",
    "sdk",
    "useWidget",
    "platform-adapter"
  ],
  "author": "Stern Development Team",
  "license": "MIT"
}
