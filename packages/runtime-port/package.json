{
  "name": "@marketsui/runtime-port",
  "version": "0.1.0",
  "description": "Runtime-agnostic port — interface + types that abstract OpenFin vs Browser. Foundation layer (no runtime imports).",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "rimraf dist tsconfig.tsbuildinfo && tsc",
    "watch": "tsc --watch",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "rimraf": "^5.0.5",
    "typescript": "~5.9.3",
    "vitest": "^4.1.4"
  },
  "license": "MIT"
}
