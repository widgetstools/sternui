{
  "name": "@marketsui/config-service",
  "version": "1.0.0",
  "description": "Dual-mode configuration service for MarketsUI — Dexie/IndexedDB for dev, REST + Dexie for prod",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "rimraf dist tsconfig.tsbuildinfo && tsc --project tsconfig.json",
    "typecheck": "tsc --noEmit --project tsconfig.json"
  },
  "dependencies": {
    "dexie": "^4.4.2"
  },
  "devDependencies": {
    "rimraf": "^5.0.5",
    "typescript": "~5.9.3"
  },
  "files": [
    "dist"
  ]
}
