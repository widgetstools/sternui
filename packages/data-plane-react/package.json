{
  "name": "@marketsui/data-plane-react",
  "version": "0.1.0",
  "description": "React hooks for @marketsui/data-plane \u2014 context provider + useDataPlaneValue / useDataPlaneAppData / useDataPlaneRowStream",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "rimraf dist tsconfig.tsbuildinfo && tsc --project tsconfig.json",
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@marketsui/data-plane": "*",
    "@marketsui/shared-types": "*"
  },
  "peerDependencies": {
    "react": ">=19.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "jsdom": "^29.0.0",
    "react": "~19.2.5",
    "react-dom": "~19.2.5",
    "rimraf": "^6.0.1",
    "typescript": "~5.9.3",
    "vitest": "^4.1.4"
  },
  "files": [
    "dist"
  ]
}
