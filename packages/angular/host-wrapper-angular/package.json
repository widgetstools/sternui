    "rxjs": ">=7.0.0"
  },
  "devDependencies": {
    "@angular/common": "21.1.0",
    "@angular/compiler": "21.1.0",
    "@angular/compiler-cli": "21.1.0",
    "@angular/core": "21.1.0",
    "@starui/config-service": "*",
    "@starui/runtime-port": "*",
    "ng-packagr": "^17.3.0",
    "rimraf": "^5.0.5",
    "rxjs": "~7.8.2",
    "typescript": "~5.9.3"
  },
