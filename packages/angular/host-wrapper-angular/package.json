{
  "name": "@starui/host-wrapper-angular",
  "version": "0.1.0",
  "description": "Angular HostService — Seam #2 (Angular flavor) from docs/ARCHITECTURE.md. Mirrors @starui/host-wrapper-react: hosted Angular components inject HostService to read identity, configManager, theme, and runtime lifecycle events.",
  "type": "module",
  "main": "dist/fesm2022/starui-host-wrapper-angular.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/fesm2022/starui-host-wrapper-angular.mjs",
      "default": "./dist/fesm2022/starui-host-wrapper-angular.mjs"
    }
  },
  "scripts": {
    "build": "ng-packagr -p ng-package.json",
    "watch": "ng-packagr -p ng-package.json --watch",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@angular/common": ">=21.0.0",
    "@angular/core": ">=21.0.0",
    "@starui/config-service": "1.0.0",
