{
  "name": "@starui/data-services-angular",
  "version": "0.1.0",
  "description": "Angular adapter for @starui/data-services — provideDataServices() factory + DataServicesService + injectAppData / injectProviderStream / injectDataProviderConfig / injectResolvedCfg helpers. Mirrors @starui/data-services-react over the same vanilla TS core.",
  "type": "module",
  "main": "dist/fesm2022/starui-data-services-angular.mjs",
  "types": "dist/types/starui-data-services-angular.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/starui-data-services-angular.d.ts",
      "import": "./dist/fesm2022/starui-data-services-angular.mjs",
      "default": "./dist/fesm2022/starui-data-services-angular.mjs"
    }
  },
  "scripts": {
    "build": "ng-packagr -p ng-package.json",
    "watch": "ng-packagr -p ng-package.json --watch",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@angular/common": "^21.2.13",
    "@angular/core": "^21.2.13",
    "@starui/data-services": "*",
    "@starui/runtime-port": "*",
    "@starui/shared-types": "*",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@angular/common": "^21.2.13",
    "@angular/compiler": "^21.2.13",
    "@angular/compiler-cli": "^21.2.13",
    "@angular/core": "^21.2.13",
    "@starui/data-services": "*",
    "@starui/runtime-port": "*",
    "@starui/shared-types": "*",
    "ng-packagr": "^21.2.3",
    "rimraf": "^6.0.1",
    "rxjs": "~7.8.2",
    "typescript": "~5.9.3"
  },
  "license": "MIT"
}
