    "ag-grid-community": ">=35.0.0",
    "ag-grid-enterprise": ">=35.0.0",
    "@stomp/stompjs": ">=7.0.0",
    "@marketsui/shared-types": "1.0.0",
    "@marketsui/openfin-platform-stern": "1.0.0",
    "@marketsui/widget-sdk": "1.0.0",
    "rxjs": ">=7.0.0"
  },
  "devDependencies": {
    "@angular/common": "21.1.0",
    "@angular/compiler": "21.1.0",
    "@angular/compiler-cli": "21.1.0",
    "@angular/core": "21.1.0",
    "@angular/forms": "21.1.0",
    "ag-grid-angular": "35.1.0",
    "ag-grid-community": "35.1.0",
    "ag-grid-enterprise": "35.1.0",
    "@stomp/stompjs": "^7.3.0",
    "ng-packagr": "^17.3.0",
    "rimraf": "^5.0.5",
    "rxjs": "~7.8.2",
    "typescript": "~5.9.3"
