    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@angular/common": ">=17.0.0",
    "@angular/core": ">=17.0.0",
    "@angular/forms": ">=17.0.0",
    "ag-grid-angular": ">=33.0.0",
    "ag-grid-community": ">=33.0.0",
    "ag-grid-enterprise": ">=33.0.0",
    "@stomp/stompjs": ">=7.0.0",
    "@marketsui/shared-types": "1.0.0",
    "@marketsui/openfin-platform-stern": "1.0.0",
    "@marketsui/widget-sdk": "1.0.0",
    "rxjs": ">=7.0.0"
  },
  "devDependencies": {
    "@angular/common": "^17.3.0",
    "@angular/compiler": "^17.3.0",
    "@angular/compiler-cli": "^17.3.0",
    "@angular/core": "^17.3.0",
    "@angular/forms": "^17.3.0",
    "ag-grid-angular": "^33.0.0",
    "ag-grid-community": "^33.0.0",
    "ag-grid-enterprise": "^33.0.0",
    "@stomp/stompjs": "^7.3.0",
    "ng-packagr": "^17.3.0",
    "rimraf": "^5.0.5",
    "rxjs": "^7.8.0",
    "typescript": "~5.4.0"
