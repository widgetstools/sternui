{
  "name": "@marketsui/angular",
  "version": "1.0.0",
  "description": "Stern Angular component library — DockConfigurator and DataProviderEditor",
  "type": "module",
  "main": "dist/fesm2022/stern-angular.mjs",
  "types": "dist/index.d.ts",
