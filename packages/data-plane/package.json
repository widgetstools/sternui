{
  "name": "@marketsui/data-plane",
  "version": "0.1.0",
  "description": "SharedWorker-backed data-plane runtime for MarketsUI — one connection per provider, N consumers multiplex over it",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./v2": {
      "import": "./dist/v2/index.js",
      "types": "./dist/v2/index.d.ts"
    },
    "./v2/worker": {
      "import": "./dist/v2/worker/index.js",
      "types": "./dist/v2/worker/index.d.ts"
    },
    "./v2/client": {
      "import": "./dist/v2/client/index.js",
      "types": "./dist/v2/client/index.d.ts"
    }
  },
  "scripts": {
    "build": "rimraf dist tsconfig.tsbuildinfo && tsc --project tsconfig.json",
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@marketsui/shared-types": "*",
    "@marketsui/config-service": "*"
  },
  "peerDependencies": {
    "@stomp/stompjs": "^7.3.0"
  },
  "peerDependenciesMeta": {
    "@stomp/stompjs": {
      "optional": true
    }
  },
  "devDependencies": {
    "@stomp/stompjs": "^7.3.0",
    "@types/node": "^22.19.17",
    "rimraf": "^6.0.1",
    "typescript": "~5.9.3",
    "vitest": "^4.1.4"
  },
  "files": [
    "dist"
  ]
}
