{
  "name": "@starui/engine",
  "version": "0.1.0",
  "private": true,
  "description": "Vanilla TS grid engine — GridPlatform, ProfileManager, ExpressionEngine (ported from @starui/core)",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "rimraf dist tsconfig.tsbuildinfo && tsc && vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "ag-grid-community": "^35.1.0",
    "ag-grid-enterprise": "^35.1.0",
    "ag-grid-react": "^35.1.0"
  },
  "dependencies": {
    "@starui/types": "*",
    "ssf": "^0.11.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "ag-grid-community": "35.1.0",
    "ag-grid-enterprise": "35.1.0",
    "ag-grid-react": "35.1.0",
    "jsdom": "^29.0.2",
    "rimraf": "^6.0.1",
    "typescript": "~5.9.3",
    "vite": "~7.3.2",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.4"
  }
}
