    --sf-t-slow:     420ms cubic-bezier(0.4,0,0.2,1);
    --sf-t-tick:     900ms cubic-bezier(0.25,0.1,0.25,1);

    /* ── Control density tiers (compact controls — see tokens/controls.ts) ── */
    --ds-control-xs-height:       24px;
