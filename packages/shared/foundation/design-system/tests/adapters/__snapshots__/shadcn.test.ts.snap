    /* ── Typography vars ── */
    --ds-font-sans:  'Inter', system-ui, -apple-system, 'Segoe UI', 'Geist', sans-serif;
    --ds-font-mono:  'JetBrains Mono', 'IBM Plex Mono', ui-monospace, 'SF Mono', monospace;
    --ds-font-serif: 'Geist', Georgia, serif;
    --ds-font-size-2xs: 10px;
    --ds-font-size-xs:  11px;
    --ds-font-size-sm:  12px;
    --ds-font-size-md:  13px;
    --ds-font-size-lg:  14px;
    --ds-font-size-xl:  16px;
    --ds-font-size-2xl: 20px;
    --ds-font-size-3xl: 28px;
    --ds-font-size-4xl: 40px;
    --ds-font-size-5xl: 56px;
    --ds-font-variant-tabular: tabular-nums;
    --ds-radius-sm:   3px;
    --ds-radius-md:   3px;
    --ds-radius-lg:   3px;
    --ds-radius-xl:   6px;
    --ds-radius-full: 9999px;
    --radius:         3px;

    /* ── Motion vars (Stockflux tokens.css) ── */
    --ds-tx-instant: 80ms cubic-bezier(0.4,0,0.6,1);
