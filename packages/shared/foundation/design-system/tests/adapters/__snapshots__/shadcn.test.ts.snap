    --ds-chart-2: #2dd4bf;
    --ds-chart-3: #f5c14b;
    --ds-chart-4: #af7de8;
    --ds-chart-5: #f25668;

    /* ── shadcn-compat HSL channel aliases (Stockflux SLATE BLUE) ── */
    --background:             215 10% 10%;
    --foreground:             215 10% 94%;
    --card:                   215 9% 13%;
    --card-foreground:        215 10% 94%;
    --popover:                215 9% 16%;
