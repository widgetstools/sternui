    --bn-bg-sunken: #ffffff;
    --bn-bg1:       #ffffff;
    --bn-bg2:       #e9ecf0;
    --bn-bg3:       #dde1e7;
    --bn-bg4:       #c8cdd5;
    --bn-t0:        #18222f;
    --bn-t1:        #2f3a4a;
    --bn-t2:        #525d6c;
    --bn-t3:        #7a8392;
    --bn-t4:        #abb1bb;
    --bn-border:    #d4d8de;
    --bn-border2:   #b6bbc4;
    --bn-border3:   #8e94a0;
    --bn-green:     #0f766e;
    --bn-green2:    #0a5d56;
    --bn-red:       #be1f43;
    --bn-red2:      #9e1838;
    --bn-amber:     #b27607;
    --bn-blue:      #2563eb;
    --bn-blue2:     #1d4ed8;
    --bn-info:      #0e7490;
    --bn-cyan:      #06b6d4;
    --bn-purple:    #7631c4;
    --bn-buy-bg:    #0f766e;
    --bn-sell-bg:   #be1f43;
    --bn-cta-text:  #ffffff;
    --ob-bid-fill:  rgba(15,118,110,0.13);
    --ob-ask-fill:  rgba(190,31,67,0.11);
    --tt-bid-strip: rgba(15,118,110,0.04);
    --tt-ask-strip: rgba(190,31,67,0.04);
    
    /* ── Stockflux --sf-* aliases (SLATE BLUE) ── */
    --sf-bg:        #f1f3f6;
    --sf-bg-1:      #ffffff;
    --sf-bg-2:      #ffffff;
    --sf-bg-3:      #e9ecf0;
    --sf-bg-4:      #dde1e7;
    --sf-bg-5:      #c8cdd5;
    --sf-t-0:       #18222f;
    --sf-t-1:       #2f3a4a;
    --sf-t-2:       #525d6c;
    --sf-t-3:       #7a8392;
    --sf-t-4:       #abb1bb;
    --sf-border:    #d4d8de;
    --sf-border-2:  #b6bbc4;
    --sf-border-3:  #8e94a0;
    --sf-teal:      #2563eb;
    --sf-teal-hi:   #1d4ed8;
    --sf-teal-lo:   #1e40af;
    --sf-teal-soft: rgba(37,99,235,0.10);
    --sf-teal-ring: rgba(37,99,235,0.28);
    --sf-up:        #0f766e;
    --sf-up-hi:     #0a5d56;
    --sf-up-soft:   rgba(15,118,110,0.10);
    --sf-up-strip:  rgba(15,118,110,0.04);
    --sf-down:      #be1f43;
    --sf-down-hi:   #9e1838;
    --sf-down-soft: rgba(190,31,67,0.10);
    --sf-down-strip:rgba(190,31,67,0.04);
    --sf-flat:      #525d6c;
    --sf-info:      #0e7490;
    --sf-info-soft: rgba(14,116,144,0.10);
    --sf-warn:      #b27607;
    --sf-warn-soft: rgba(178,118,7,0.11);
    --sf-success:   #0f766e;
    --sf-error:     #be1f43;
    --sf-bid-fill:  rgba(15,118,110,0.13);
    --sf-ask-fill:  rgba(190,31,67,0.11);
    --sf-scrollbar: #b6bbc4;
  }

  [data-theme="dark"][data-cvd="on"] {
    --ds-accent-positive:       #7aa6ff;
    --ds-accent-positive-hover: #7aa6ff;
    --ds-accent-negative:       #ff9d4e;
    --ds-accent-negative-hover: #ff9d4e;
    --ds-action-buy-bg:         #7aa6ff;
    --ds-action-sell-bg:        #ff9d4e;
    --success:                  220 100% 74%;
    --destructive:              27 100% 65%;
  }

  [data-theme="light"][data-cvd="on"] {
    --ds-accent-positive:       #1e4fb8;
    --ds-accent-positive-hover: #1e4fb8;
    --ds-accent-negative:       #c2410c;
    --ds-accent-negative-hover: #c2410c;
    --ds-action-buy-bg:         #1e4fb8;
    --ds-action-sell-bg:        #c2410c;
    --success:                  221 72% 42%;
    --destructive:              17 88% 40%;
  }
}"
`;
