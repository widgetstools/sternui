{
  "name": "@starui/core",
  "version": "0.1.0",
  "description": "MarketsUI core — GridPlatform, modules, LayoutManager, HistoryStack, ExpressionEngine. Framework-agnostic TypeScript foundation.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && vite build",
    "build:lib": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "ag-grid-community": ">=35.0.0",
    "ag-grid-enterprise": ">=35.0.0",
    "ag-grid-react": ">=35.0.0"
  },
  "dependencies": {
    "@starui/shared-types": "*",
    "dexie": "^4.4.2",
    "ssf": "^0.11.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "ag-grid-community": "35.1.0",
    "ag-grid-enterprise": "35.1.0",
    "ag-grid-react": "35.1.0",
    "jsdom": "^29.0.2",
    "typescript": "~5.9.3",
    "vite": "~7.3.2",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.4"
  }
}
