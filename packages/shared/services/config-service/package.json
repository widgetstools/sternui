{
  "name": "@starui/config-service",
  "version": "1.0.0",
  "description": "Dual-mode configuration service for MarketsUI — Dexie/IndexedDB for dev, REST + Dexie for prod",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "rimraf dist tsconfig.tsbuildinfo && tsc --project tsconfig.json",
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "dexie": "^4.4.2"
  },
  "peerDependencies": {
    "@starui/core": "*"
  },
  "peerDependenciesMeta": {
    "@starui/core": {
      "optional": true
    }
  },
  "devDependencies": {
    "@starui/core": "*",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.0.2",
    "rimraf": "^6.0.1",
    "typescript": "~5.9.3",
    "vitest": "^4.1.4"
  },
  "files": [
    "dist"
  ]
}
