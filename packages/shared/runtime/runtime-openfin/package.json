{
  "name": "@starui/runtime-openfin",
  "version": "0.1.0",
  "description": "OpenFin implementation of @starui/runtime-port. Reads identity from view customData, bridges fin.* lifecycle events.",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "rimraf dist tsconfig.tsbuildinfo && tsc",
    "watch": "tsc --watch",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@starui/runtime-port": "0.1.0",
    "@starui/runtime-browser": "0.1.0"
  },
  "peerDependencies": {
    "@openfin/core": "43.101.2"
  },
  "peerDependenciesMeta": {
    "@openfin/core": {
      "optional": true
    }
  },
  "devDependencies": {
    "@openfin/core": "43.101.2",
    "rimraf": "^6.0.1",
    "typescript": "~5.9.3",
    "vitest": "^4.1.4"
  },
  "license": "MIT"
}
