# /libs/ tarballs (produced by `npm run pack:libs`) are tracked so a
# fresh clone + `npm ci` works without first running pack:libs.
# Regenerate via `npm run pack:libs` whenever a library's source or
# package.json changes (CI should enforce this in a follow-up).

/cell-format-toolbar*.html
/toolbar-teal*.html

# Accidentally committed TS compiler output in app src/ trees.
# Ambient .d.ts files under any `src/types/` directory are intentional and tracked.
apps/*/src/**/*.js
apps/*/src/**/*.js.map
apps/*/src/**/*.d.ts.map
apps/markets-ui-react-reference/src/App.d.ts
apps/markets-ui-react-reference/src/main.d.ts
apps/markets-ui-react-reference/src/platform/Provider.d.ts
apps/markets-ui-react-reference/src/lib/utils.d.ts
apps/markets-ui-react-reference/src/components/ui/*.d.ts
apps/markets-ui-react-reference/src/views/*.d.ts

# Angular compiler cache — local build artifact, not source
apps/*/.angular/

# Config-service-server runtime artifacts
apps/config-service-server/logs/
apps/config-service-server/data/*.db

# Local dotenv overrides — `.env.example` is the tracked template
.env.local
.env.*.local

# User reference materials (kept locally, not committed)
Markets Design System-latest/
Markets Design System-latest.zip
Markets Design System*.zip
.app-shell-pr-body.md

# Browser screenshots captured during visual review
.tmp-screenshots/
