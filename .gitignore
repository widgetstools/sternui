# Accidentally committed TS compiler output in app src/ trees.
# Ambient .d.ts files under any `src/types/` directory are intentional and tracked.
apps/*/src/**/*.js
apps/*/src/**/*.js.map
apps/*/src/**/*.d.ts.map
apps/markets-ui-react-reference/src/App.d.ts
