{
  "name": "@stargrid/host-config",
  "version": "0.1.0",
  "private": true,
  "description": "ConfigManager + Dexie/REST persistence for StarGrid host ports",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "rimraf dist tsconfig.tsbuildinfo && tsc --project tsconfig.json",
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "dexie": "^4.4.2"
  },
  "peerDependencies": {
    "@stargrid/engine": "*"
  },
  "peerDependenciesMeta": {
    "@stargrid/engine": {
      "optional": true
    }
  },
  "devDependencies": {
    "@stargrid/engine": "*",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.0.2",
    "rimraf": "^6.0.1",
    "typescript": "~5.9.3",
    "vitest": "^4.1.4"
  }
}
