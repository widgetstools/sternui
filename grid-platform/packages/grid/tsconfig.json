{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@stargrid/grid": ["./src/index.ts"],
      "@stargrid/grid/customizer": ["./src/customizer/index.ts"],
      "@stargrid/engine": ["../engine/src/index.ts"],
      "@stargrid/types": ["../types/src/index.ts"],
      "@stargrid/host": ["../host/src/index.ts"],
      "@stargrid/ui": ["../ui/src/index.ts"],
      "@stargrid/design-system": ["../design-system/src/index.ts"]
    },
    "noEmit": true
  },
  "include": ["src"],
  "exclude": ["src/**/*.test.ts", "src/**/*.test.tsx"],
  "references": [
    { "path": "../types" },
    { "path": "../host" },
    { "path": "../engine" }
  ]
}
