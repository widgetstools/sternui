{
  "name": "@stargrid/host-browser",
  "version": "0.1.0",
  "private": true,
  "description": "Browser RuntimePort implementation for StarGrid",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "rimraf dist tsconfig.tsbuildinfo && tsc --project tsconfig.json",
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@stargrid/host": "*",
    "@stargrid/types": "*"
  },
  "devDependencies": {
    "jsdom": "^29.0.2",
    "rimraf": "^6.0.1",
    "typescript": "~5.9.3",
    "vitest": "^4.1.4"
  }
}
