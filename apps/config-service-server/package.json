{
  "name": "@starui/config-service-server",
  "version": "1.0.0",
  "description": "Stern Configuration Service — REST API with hierarchical config support",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "build": "tsc && node scripts/copy-admin-web.mjs",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@starui/shared-types": "1.0.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^6.8.1",
    "helmet": "^7.1.0",
    "joi": "^17.12.0",
    "sql.js": "^1.13.0",
    "uuid": "^9.0.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.19.17",
    "@types/sql.js": "^1.4.9",
    "@types/uuid": "^9.0.7",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.2",
    "typescript": "~5.9.3",
    "vitest": "^4.1.4",
    "supertest": "^6.3.4",
    "@types/supertest": "^6.0.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
