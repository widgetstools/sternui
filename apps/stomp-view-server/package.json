{
  "name": "@starui/stomp-view-server",
  "private": true,
  "version": "1.0.0",
  "description": "Lightweight TypeScript STOMP view server for demo apps. Serves synthetic fixed-income snapshots + live updates; consumed in-monorepo by the StompDataProvider via ws://localhost:8081.",
  "type": "module",
  "main": "dist/main.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "rimraf dist && tsc",
    "start": "node dist/main.js",
    "dev": "tsx watch src/main.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "dotenv": "^16.5.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "@types/ws": "^8.5.13",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.2",
    "typescript": "~5.9.3"
  },
  "license": "ISC"
}
