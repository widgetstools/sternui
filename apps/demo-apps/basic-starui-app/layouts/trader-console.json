              "enabled": true,
              "priority": 60,
              "scope": { "type": "cell", "columns": ["midPrice"] },
              "expression": "[midPrice] > 0",
              "style": { "light": {}, "dark": {} },
              "flash": { "enabled": true, "target": "cells", "flashDuration": 300, "fadeDuration": 700 }
            }
          ]
