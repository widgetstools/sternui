        "v": 1,
        "data": {
          "rules": [
            {
              "id": "rule-side-bid",
              "name": "BID indicator",
              "enabled": true,
              "priority": 10,
              "scope": { "type": "cell", "columns": ["side"] },
              "expression": "[side] == 'BID'",
              "style": {
                "light": { "backgroundColor": "rgba(5, 150, 105, 0.14)", "color": "#047857", "fontWeight": "700" },
                "dark":  { "backgroundColor": "rgba(45, 212, 191, 0.18)", "color": "#5eead4", "fontWeight": "700" }
              }
            },
            {
              "id": "rule-side-offer",
              "name": "OFFER indicator",
              "enabled": true,
              "priority": 11,
              "scope": { "type": "cell", "columns": ["side"] },
              "expression": "[side] == 'OFFER'",
              "style": {
                "light": { "backgroundColor": "rgba(220, 38, 38, 0.12)", "color": "#b91c1c", "fontWeight": "700" },
                "dark":  { "backgroundColor": "rgba(248, 113, 113, 0.18)", "color": "#fca5a5", "fontWeight": "700" }
              }
            },
            {
              "id": "rule-side-twoway",
              "name": "TWO-WAY indicator",
              "enabled": true,
              "priority": 12,
              "scope": { "type": "cell", "columns": ["side"] },
              "expression": "[side] == 'TWO-WAY'",
              "style": {
                "light": { "backgroundColor": "rgba(56, 189, 248, 0.14)", "color": "#0369a1", "fontWeight": "700" },
                "dark":  { "backgroundColor": "rgba(56, 189, 248, 0.18)", "color": "#7dd3fc", "fontWeight": "700" }
              }
            },
            {
              "id": "rule-change-up",
              "name": "Yield up (sold off)",
              "enabled": true,
              "priority": 20,
              "scope": { "type": "cell", "columns": ["changeBps"] },
              "expression": "[changeBps] > 5",
              "style": {
                "light": { "color": "#b91c1c", "fontWeight": "600" },
                "dark":  { "color": "#fca5a5", "fontWeight": "600" }
              },
              "flash": { "enabled": true, "target": "cells", "flashDuration": 300, "fadeDuration": 700 }
            },
            {
              "id": "rule-change-down",
              "name": "Yield down (rallied)",
              "enabled": true,
              "priority": 21,
              "scope": { "type": "cell", "columns": ["changeBps"] },
              "expression": "[changeBps] < -5",
              "style": {
                "light": { "color": "#047857", "fontWeight": "600" },
                "dark":  { "color": "#5eead4", "fontWeight": "600" }
              },
              "flash": { "enabled": true, "target": "cells", "flashDuration": 300, "fadeDuration": 700 }
            },
            {
              "id": "rule-pnl-positive",
              "name": "P&L positive",
              "enabled": true,
              "priority": 30,
              "scope": { "type": "cell", "columns": ["pnlDay"] },
              "expression": "[pnlDay] > 0",
              "style": {
                "light": { "color": "#047857" },
                "dark":  { "color": "#34d399" }
              }
            },
            {
              "id": "rule-pnl-negative",
              "name": "P&L negative",
              "enabled": true,
              "priority": 31,
              "scope": { "type": "cell", "columns": ["pnlDay"] },
              "expression": "[pnlDay] < 0",
              "style": {
                "light": { "color": "#b91c1c" },
                "dark":  { "color": "#fca5a5" }
              }
            },
            {
              "id": "rule-rating-hy",
              "name": "High-yield rating tint",
              "enabled": true,
              "priority": 40,
              "scope": { "type": "cell", "columns": ["rating"] },
              "expression": "[rating] == 'BB+' || [rating] == 'BB' || [rating] == 'BB-' || [rating] == 'B+' || [rating] == 'B'",
              "style": {
                "light": { "backgroundColor": "rgba(245, 158, 11, 0.16)", "color": "#92400e", "fontWeight": "700" },
                "dark":  { "backgroundColor": "rgba(245, 158, 11, 0.20)", "color": "#fcd34d", "fontWeight": "700" }
              }
            },
            {
              "id": "rule-bidask-wide",
              "name": "Wide bid-ask (>30 bps)",
              "enabled": true,
              "priority": 50,
              "scope": { "type": "cell", "columns": ["bidAskBps"] },
              "expression": "[bidAskBps] > 30",
              "style": {
                "light": { "backgroundColor": "rgba(245, 158, 11, 0.16)", "color": "#92400e" },
                "dark":  { "backgroundColor": "rgba(245, 158, 11, 0.20)", "color": "#fcd34d" }
