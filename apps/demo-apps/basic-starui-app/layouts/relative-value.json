                "dark":  { "backgroundColor": "rgba(56, 189, 248, 0.18)", "color": "#7dd3fc" }
              }
            },
            {
              "id": "rule-sector-treasury",
              "name": "Treasury / Sovereign row tint",
              "enabled": true,
              "priority": 30,
              "scope": { "type": "row" },
