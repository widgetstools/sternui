{
  "name": "@marketsui/stern-reference-react",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port 5173",
    "build": "export NODE_OPTIONS=--disable-warning=ExperimentalWarning && tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "openfin": "node ../../tools/scripts/launch-openfin.mjs http://localhost:5173/manifest.fin.json",
    "dev:openfin": "concurrently -k -n vite,openfin -c cyan,magenta \"npm run dev -- --no-open\" \"wait-on http://localhost:5173 && npm run openfin\""
  },
  "dependencies": {
    "@openfin/core": "43.101.4",
    "@openfin/workspace": "23.0.20",
    "@openfin/workspace-platform": "23.0.20",
    "@marketsui/openfin-platform-stern": "1.0.0",
    "@marketsui/shared-types": "1.0.0",
    "@marketsui/tokens-primeng": "1.0.0",
    "@marketsui/ui": "1.0.0",
    "@marketsui/widget-sdk": "1.0.0",
    "@marketsui/widgets-react": "1.0.0",
    "@tanstack/react-query": "^5.80.7",
    "react": "~19.2.5",
    "react-dom": "~19.2.5",
    "react-router-dom": "^7.1.5"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "~4.5.2",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "tailwindcss": "3.4.1",
    "typescript": "~5.9.3",
    "vite": "~7.3.2"
  }
}
