{
  "name": "@starui/demo-angular",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development"
  },
  "private": true,
  "packageManager": "npm@11.3.0",
  "//dependencies-registry-notes": {
    "description": "All packages resolve from the public npm registry. Versions are pinned to the stable line for each major rather than tracking latest, so the app does not pull bleeding-edge releases.",
    "pinning-strategy": "Exact pins for Angular core, AG Grid, and @widgetstools dock-manager; tilde (~) for PrimeNG runtime and Chart.js. Update intentionally, not automatically.",
    "stable-vs-latest": {
      "@angular/*": "21.1.0 stable (public latest is 21.2.x — intentionally trailing)",
      "@angular/build": "21.1.0 (public latest 21.2.x)",
      "@angular/cli": "21.1.0 (public latest 21.2.x)",
      "@primeng/themes": "20.3.0 (kept on the 20 line to match the installed @primeuix/themes 1.2.5 transitive; bump to 21.x when PrimeNG runtime moves up)",
      "ag-grid-*": "35.1.0 (public latest 35.2.x)",
      "chart.js": "~4.4.9 (public latest 4.5.x)"
    }
  },
  "dependencies": {
    "@starui/design-system": "*",
    "tailwindcss": "3.4.1",
    "tailwindcss-primeui": "^0.6.1",
    "tailwindcss-animate": "^1.0.7",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.9",
    "@angular/animations": "21.1.0",
    "@angular/cdk": "21.1.0",
    "@angular/common": "21.1.0",
    "@angular/compiler": "21.1.0",
    "@angular/core": "21.1.0",
    "@angular/forms": "21.1.0",
    "@angular/platform-browser": "21.1.0",
    "@angular/router": "21.1.0",
    "@primeng/themes": "20.3.0",
    "@widgetstools/angular-dock-manager": "1.0.0",
    "@widgetstools/dock-manager-core": "1.0.0",
    "ag-grid-angular": "35.1.0",
    "ag-grid-community": "35.1.0",
    "ag-grid-enterprise": "35.1.0",
    "chart.js": "~4.4.9",
    "primeng": "~21.1.5",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular/build": "21.1.0",
    "@angular/cli": "21.1.0",
    "@angular/compiler-cli": "21.1.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.3"
  }
}
